# Copy this file to `.env` and populate only the keys needed for the current run.
OPENAI_API_KEY=
REWARDLAB_DATA_DIR=.rewardlab
REWARDLAB_DB_PATH=.rewardlab/metadata.sqlite3
REWARDLAB_EVENT_LOG_DIR=.rewardlab/events
REWARDLAB_CHECKPOINT_DIR=.rewardlab/checkpoints
REWARDLAB_REPORT_DIR=.rewardlab/reports
